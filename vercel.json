{
  "functions": {
    "api/audit.js": {
      "maxDuration": 60
    }
  },
  "redirects": [
    { "source": "/services/brand-identity", "destination": "/services/", "permanent": true },
    { "source": "/services/brand-identity/", "destination": "/services/", "permanent": true },
    { "source": "/services/web-design", "destination": "/services/website-design/", "permanent": true },
    { "source": "/services/web-design/", "destination": "/services/website-design/", "permanent": true },
    { "source": "/services/product-sourcing", "destination": "/services/custom-packaging/", "permanent": true },
    { "source": "/services/product-sourcing/", "destination": "/services/custom-packaging/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/audit", "destination": "/api/audit.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/audit", "destination": "/audit.html" },
    { "source": "/audit-results", "destination": "/audit-results.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
